# Job Automation Suite Configuration
# -----------------------------------------------------------------------------

# GitHub State Persistence (Optional)
# Set USE_GITHUB_DATA=true to fetch job data from your GitHub data-state branch
# Set USE_GITHUB_DATA=false to read data from local /app/job-scraping-app/data/ folder
USE_GITHUB_DATA=false

# GitHub Credentials (Required only if USE_GITHUB_DATA=true or for automated backups)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPOSITORY=your_username/Job-Automation-Suite

# AI Resume Tailoring (Optional)
# Add your API keys here to enable AI-powered CV keyword optimization and tailoring
# OPENAI_API_KEY=your_openai_api_key
# DEEPSEEK_API_KEY=your_deepseek_api_key
